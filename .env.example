# Copy to `.env` and fill in. Everything is optional: with the defaults below
# (fake backends) the system runs with NO external keys.
#
# Config is organized into three swappable provider slots. The var NAMES are
# vendor-neutral; the values shown are ONE example combination (Groq + Jina +
# Qdrant), not privileged defaults — any provider behind each interface works
# the same way.

# --- LLM slot ---
# LLM_BACKEND: fake | groq | ...
LLM_BACKEND=fake
# Key for the selected LLM backend (e.g. your Groq key when LLM_BACKEND=groq).
LLM_API_KEY=
MODEL=llama-3.3-70b-versatile

# --- Embedder slot ---
# EMBED_BACKEND: fake | jina | ...
EMBED_BACKEND=fake
# Key for the selected embedder backend (e.g. your Jina key when EMBED_BACKEND=jina).
EMBED_API_KEY=
# Dimension travels with the embedder (Jina v3 = 1024, OpenAI 3-small = 1536).
EMBED_DIM=1024

# --- Vector store slot ---
# STORE_BACKEND: qdrant | ...
STORE_BACKEND=qdrant
COLLECTION=atomir_memories
# If STORE_URL is set -> server mode; otherwise embedded/local at STORE_PATH.
STORE_URL=
STORE_PATH=./qdrant_data
