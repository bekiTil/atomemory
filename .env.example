# Copy to `.env` and fill in. Everything is optional: with the defaults below
# (fake backends) the system runs with NO external keys.
#
# Config is organized into three swappable provider slots. The var NAMES are
# vendor-neutral; the values shown are ONE example combination (Groq + Jina +
# Qdrant), not privileged defaults — any provider behind each interface works
# the same way.

# --- LLM slot ---
# LLM_BACKEND: fake | groq | openai | anthropic | ollama
LLM_BACKEND=fake
# Key for the selected LLM backend (not needed for fake or ollama).
LLM_API_KEY=
# Model for the backend, e.g. groq: llama-3.3-70b-versatile | openai: gpt-4o-mini
# | anthropic: claude-haiku-4-5-20251001 | ollama: llama3.1
MODEL=llama-3.3-70b-versatile
# Optional: override the endpoint (Azure/proxy/OpenAI-compatible, or Ollama host).
LLM_BASE_URL=
# Leave unset for the provider's default. 0 is recommended: measured same
# sub-question quality with fewer run-to-run changes (see eval/temp_ab.py).
LLM_TEMPERATURE=0

# --- Embedder slot ---
# EMBED_BACKEND: fake | jina | voyage | openai | ollama
EMBED_BACKEND=fake
# Key for the selected embedder backend (not needed for fake or ollama).
EMBED_API_KEY=
# Dimension MUST match the model: jina v3 = 1024, voyage-3 = 1024,
# openai 3-small = 1536, ollama nomic-embed-text = 768. You cannot mix
# embedders in one collection — switching means a fresh collection / re-embed.
EMBED_DIM=1024
EMBED_BASE_URL=

# --- Retrieval tuning ---
# Hybrid read: fuse dense (embedding) + lexical (BM25) rankings with RRF. Helps
# queries that hinge on rare terms (names, titles); set false for dense-only.
HYBRID_SEARCH=true

# --- Reconciler tuning ---
# Write-side similarity gate: a candidate whose nearest fact scores below this
# is ADDed directly (distinct facts must not over-merge). Tuned via eval/tune.py
# for Jina; re-tune per embedder (it's dimension/space dependent).
RECONCILE_MIN_SIM=0.5

# --- Vector store slot ---
# STORE_BACKEND: qdrant | ...
STORE_BACKEND=qdrant
COLLECTION=atomir_memories
# If STORE_URL is set -> server mode; otherwise embedded/local at STORE_PATH.
STORE_URL=
STORE_PATH=./qdrant_data
